{
  "name": "@blaeu/preset-cadastre",
  "version": "0.1.0",
  "description": "Cadastre / land registry preset. Turkish CRS defaults, topological editing, mm precision.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@blaeu/plugin-snap": "^0.1.0",
    "@blaeu/plugin-draw": "^0.1.0",
    "@blaeu/plugin-edit": "^0.1.0",
    "@blaeu/plugin-select": "^0.1.0",
    "@blaeu/plugin-measure": "^0.1.0",
    "@blaeu/plugin-history": "^0.1.0",
    "@blaeu/plugin-topology": "^0.1.0",
    "@blaeu/plugin-ui": "^0.1.0"
  },
  "peerDependencies": {
    "@blaeu/core": "^0.1.0"
  },
  "devDependencies": {
    "@blaeu/core": "^0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
