{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    /* Strictness. All of it. A geospatial kernel that lies about nullability
     * produces NaN coordinates, and a NaN coordinate renders as "nothing there"
     * rather than as an error — which is the hardest class of bug to find. */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "skipLibCheck": true,

    "paths": {
      "@blaeu/core": ["./packages/core/src/index.ts"],
      "@blaeu/core/testing": ["./packages/core/src/testing/index.ts"],
      "@blaeu/plugin-draw": ["./packages/plugin-draw/src/index.ts"],
      "@blaeu/plugin-edit": ["./packages/plugin-edit/src/index.ts"],
      "@blaeu/plugin-snap": ["./packages/plugin-snap/src/index.ts"],
      "@blaeu/plugin-select": ["./packages/plugin-select/src/index.ts"],
      "@blaeu/plugin-measure": ["./packages/plugin-measure/src/index.ts"],
      "@blaeu/plugin-history": ["./packages/plugin-history/src/index.ts"],
      "@blaeu/plugin-topology": ["./packages/plugin-topology/src/index.ts"],
      "@blaeu/plugin-ui": ["./packages/plugin-ui/src/index.ts"],
      "@blaeu/preset-cadastre": ["./packages/preset-cadastre/src/index.ts"],
      "@blaeu/preset-urban": ["./packages/preset-urban/src/index.ts"],
      "@blaeu/preset-game": ["./packages/preset-game/src/index.ts"]
    }
  }
}
